(do
    (def a 10)
    (assert (= a 10) "def should bind 'a' to 10")

    (set a 20)
    (assert (= a 20) "set should mutate 'a' to 20")

    (let ((a 30) (b 40))
        (assert (= a 30) "let should shadow the outer variable 'a'")
        (assert (= b 40) "let should bind local variable 'b'")
        (set a 35)
        (assert (= a 35) "set should mutate the local shadowed 'a'")
    )

    (assert (= a 20) "outer 'a' should remain unchanged after let block exits")

    (let ((x 5) (y x))
        (assert (= y 5) "'y' should be able to reference 'x' in sequential let bindings")
    )
)
