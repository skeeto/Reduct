(do
    (assert! (== (format "Hello, {}!" "World") "Hello, World!") "format should replace {} with arguments")
    (assert! (== (format "{1} {0}" "World" "Hello") "Hello World") "format should support explicit indexing")
    (assert! (== (format "No args") "No args") "format should handle strings without placeholders")

    (assert! (== (print! "test-print ") ()) "print! should return nil")
    (assert! (== (println! "test-println") ()) "println! should return nil")
    
    (assert! (== (ord "A") 65) "ord should return character ASCII code")
    (assert! (== (chr 65) "A") "chr should return character from ASCII code")

    (assert! (number? (now!)) "now! should return a number (unix timestamp)")
    
    (assert! (number? (uptime!)) "uptime! should return a number (ms since start)")

    (assert! (list? (env!)) "env! should return a list of environment variables")
    
    (assert! (list? (args!)) "args! should return the command line arguments list")

    (assert! (atom? (read-file! "01_variables_scope.rdt")) "read-file! should read a file as a string atom")
    (assert! (!= (len (read-file! "01_variables_scope.rdt")) 0) "read-file! should read non-empty content")
    
    (assert! (== (run "(+ 1 2)") 3) "run should allow dynamic code execution")
)
