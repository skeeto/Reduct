{
    "name": "reduct",
    "displayName": "Reduct Language Support",
    "description": "Syntax highlighting and language support for Reduct",
    "version": "2.0.0",
    "author": "Kai Norberg",
    "publisher": "KaiNorberg",
    "repository": {
        "type": "git",
        "url": "https://github.com/KaiNorberg/Reduct"
    },
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "keywords": [
        "reduct",
        "lisp"
    ],
    "contributes": {
        "languages": [
            {
                "id": "reduct",
                "aliases": [
                    "Reduct",
                    "reduct"
                ],
                "extensions": [
                    ".reduct",
                    ".rdt"
                ],
                "configuration": "./language-configuration.json",
                "firstLine": "^#!.*\\breduct\\b"
            }
        ],
        "grammars": [
            {
                "language": "reduct",
                "scopeName": "source.reduct",
                "path": "./syntaxes/reduct.tmLanguage.json"
            }
        ]
    }
}